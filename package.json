{
	"name": "lapkart",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:mobile": "vite build --config vite.mobile.config.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"cap:sync": "cap sync",
		"cap:copy:android": "cap copy android",
		"android:bundle": "npm run build:mobile && cap copy android",
		"android:apk": "npm run android:bundle && cd android && gradlew.bat assembleDebug",
		"android:add": "cap add android",
		"android:open": "cap open android",
		"android:run": "cap run android",
		"android:sync": "cap sync android",
		"open-design": "open-design-ade",
		"open-design:mcp": "open-design-mcp"
	},
	"dependencies": {
		"@capacitor/android": "^8.4.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/core": "^8.4.0",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/splash-screen": "^8.0.1",
		"@lucide/svelte": "^1.17.0",
		"@supabase/ssr": "^0.10.3",
		"@supabase/supabase-js": "^2.107.0",
		"tw-animate-css": "^1.3.4",
		"typesense": "^3.0.6"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^8.4.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/mcp": "^0.1.24",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"@vitejs/plugin-legacy": "^8.0.2",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"open-design-ade": "^0.4.2",
		"open-design-mcp": "^0.16.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.56.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"terser": "^5.48.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	}
}
